# Production build for GitHub Pages.
# Copy to .env.production and fill in your Render backend URL.

# Your Laravel backend on Render (no trailing slash). Example:
# VITE_API_URL=https://fit-ai-api.onrender.com/api
VITE_API_URL=https://YOUR-RENDER-SERVICE.onrender.com/api
VITE_OAUTH_URL=https://YOUR-RENDER-SERVICE.onrender.com/api
